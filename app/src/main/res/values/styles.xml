<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- グリッド/パネル用 大型ボタン（タップターゲット 48dp） -->
    <style name="NdButtonBig">
        <item name="android:layout_height">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/nd_selector</item>
        <item name="android:background">@drawable/nd_btn_bg</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- データ表示の小見出し -->
    <style name="NdCaption">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">#556066</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
