<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ND計器風パネルボタン (サイドパネル用) -->
    <style name="NdButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/nd_selector</item>
        <item name="android:background">@drawable/nd_btn_bg</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:padding">0dp</item>
    </style>

    <!-- 下部パネル用 (小さめ) -->
    <style name="NdButtonSmall">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/nd_selector</item>
        <item name="android:background">@drawable/nd_btn_bg</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:paddingHorizontal">6dp</item>
        <item name="android:paddingVertical">0dp</item>
    </style>
</resources>
