<?xml version="1.0" encoding="utf-8"?>
<!--
  スマホ縦画面: 上にレーダー（正方形）、下に情報バー + ボタングリッド。
  横画面は layout-land/activity_main.xml（左右パネル + 中央レーダー）。

  ND計器エリアは3層構成:
    [背面] mapView   = MapLibre (道路基図PMTiles + JMA雨雲ラスター)
    [前面] radarView = NdOverlayView (透過の計器オーバーレイ)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ══ 地図 (背面: 道路基図 + 雨雲) — 計器エリアと同位置・同サイズ ══ -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@+id/radarView"
        app:layout_constraintBottom_toBottomOf="@+id/radarView"
        app:layout_constraintStart_toStartOf="@+id/radarView"
        app:layout_constraintEnd_toEndOf="@+id/radarView" />

    <!-- ══ ND計器オーバーレイ (前面・透過・正方形・主役) ══ -->
    <com.wxr.radar.ui.NdOverlayView
        android:id="@+id/radarView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1" />

    <!-- ══ アラートバナー (最前面・タップでも消音) ══ -->
    <LinearLayout
        android:id="@+id/alertBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CCFF0000"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:visibility="gone"
        android:elevation="11dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ WXR CAUTION 強雨接近"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:paddingVertical="10dp" />

        <Button
            android:id="@+id/btnAlertMute"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="64dp"
            android:layout_marginStart="12dp"
            android:text="✕ 消音"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#66000000" />
    </LinearLayout>

    <!-- ══ データ受信状態バナー (常時表示・最前面) ══ -->
    <TextView
        android:id="@+id/statusBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● 受信待機"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.05"
        android:background="#CC000000"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ 下部パネル: 情報バー + ボタングリッド ══ -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#0A0A0A"
        android:paddingHorizontal="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/radarView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 情報バー: HDG / SRC / GS / 位置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView style="@style/NdCaption" android:text="HDG "/>
            <TextView android:id="@+id/tvHdg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="---°" android:textSize="18sp" android:textColor="#00CCFF"
                android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvHdgSrc"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="---" android:textSize="11sp" android:textColor="#FFAA00"
                android:fontFamily="monospace"/>

            <TextView style="@style/NdCaption" android:text="  GS "/>
            <TextView android:id="@+id/tvGs"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textColor="#FFFFFF"
                android:fontFamily="monospace"/>
            <TextView style="@style/NdCaption" android:text="km/h"/>

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvLat"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--°--N" android:textSize="10sp" android:textColor="#00E000"
                        android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tvLon"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="--°--E" android:textSize="10sp" android:textColor="#00E000"
                        android:fontFamily="monospace"/>
                </LinearLayout>
                <TextView android:id="@+id/tvSrc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="---" android:textSize="10sp" android:textColor="#00CCFF"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- グリッド1段目: RNG− | レンジ表示 | RNG+ | AUTO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button android:id="@+id/btnRangeDown"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="RNG −"/>

            <TextView android:id="@+id/tvRange"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="10 km" android:textSize="24sp" android:textColor="#50EAFF"
                android:fontFamily="monospace"
                android:background="#101418"
                android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnRangeUp"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="RNG ＋"/>

            <Button android:id="@+id/btnAuto"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:text="AUTO"/>
        </LinearLayout>

        <!-- グリッド2段目: MODE | ORIENT | 単位 | WXR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button android:id="@+id/btnMode"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="ARC"/>

            <Button android:id="@+id/btnOrient"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="HDG UP"/>

            <Button android:id="@+id/btnUnit"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="km"/>

            <Button android:id="@+id/btnWxr"
                style="@style/NdButtonBig"
                android:layout_height="56dp"
                android:layout_width="0dp" android:layout_weight="1"
                android:text="WXR"/>
        </LinearLayout>

        <!-- 凡例 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View android:layout_width="12dp" android:layout_height="8dp" android:background="#00C800"/>
            <TextView style="@style/NdCaption" android:text="10+ " android:layout_marginEnd="6dp"/>
            <View android:layout_width="12dp" android:layout_height="8dp" android:background="#C8C800"/>
            <TextView style="@style/NdCaption" android:text="30+ " android:layout_marginEnd="6dp"/>
            <View android:layout_width="12dp" android:layout_height="8dp" android:background="#C80000"/>
            <TextView style="@style/NdCaption" android:text="50+ " android:layout_marginEnd="6dp"/>
            <View android:layout_width="12dp" android:layout_height="8dp" android:background="#C800C8"/>
            <TextView style="@style/NdCaption" android:text="80+ mm/h"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
